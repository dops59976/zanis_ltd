pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = "docker.io"
        DOCKER_REPO = "YOUR_DOCKER_REPO"
        BUILD_TIMESTAMP = sh(script: "date +%Y%m%d_%H%M%S", returnStdout: true).trim()
        BUILD_TAG = "${BUILD_TIMESTAMP}_${BUILD_NUMBER}"
        LATEST_TAG = "latest"
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo "📦 Checking out source code..."
                checkout scm
                sh 'pwd && ls -la'
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo "🐳 Building Docker image..."
                sh '''
                    # Navigate to frontend directory from workspace root
                    if [ -d "zanis_ltd/frontend" ]; then
                        cd zanis_ltd/frontend
                    elif [ -d "frontend" ]; then
                        cd frontend
                    else
                        echo "❌ Frontend directory not found"
                        ls -la
                        exit 1
                    fi
                    
                    echo "Building from: $(pwd)"
                    
                    # Build with timestamp tag
                    docker build -t ${DOCKER_REPO}:${BUILD_TAG} .
                    
                    # Tag as latest
                    docker tag ${DOCKER_REPO}:${BUILD_TAG} ${DOCKER_REPO}:${LATEST_TAG}
                    
                    echo "✅ Docker images created:"
                    echo "  - ${DOCKER_REPO}:${BUILD_TAG}"
                    echo "  - ${DOCKER_REPO}:${LATEST_TAG}"
                '''
            }
        }
        
        stage('Push to Docker Hub') {
            when {
                branch 'main'
            }
            steps {
                echo "📤 Pushing Docker images to Docker Hub..."
                script {
                    withRegistry("https://${DOCKER_REGISTRY}", 'docker-registry') {
                        sh '''
                            # Push timestamp tag
                            docker push ${DOCKER_REPO}:${BUILD_TAG}
                            
                            # Push latest tag
                            docker push ${DOCKER_REPO}:${LATEST_TAG}
                            
                            echo "✅ Images pushed successfully"
                            echo "  - ${DOCKER_REPO}:${BUILD_TAG}"
                            echo "  - ${DOCKER_REPO}:${LATEST_TAG}"
                        '''
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo "🧹 Cleaning up..."
            sh '''
                docker images ${DOCKER_REPO} || true
            '''
        }
        
        success {
            echo "✅ Build successful!"
        }
        
        failure {
            echo "❌ Build failed!"
        }
    }
}
