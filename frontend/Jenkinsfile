pipeline {
    agent any
    
    stages {
        stage('Hello World') {
            steps {
                echo "🌍 Hello World from Jenkins!"
                echo "Pipeline is working correctly"
            }
        }
    }
    
    post {
        success {
            echo "✅ Build successful!"
        }
        failure {
            echo "❌ Build failed!"
        }
    }
}
